<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="The Global Forum – analysis on Politics, Geopolitics, Economics, History, Technology">
  <title>{{ title or "The Global Forum" }}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * { font-family: 'Inter', system-ui, sans-serif; }
    body { background: #f9fafb; }
    .card-hover { transition: all 0.25s ease; }
    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 25px -12px rgba(0,0,0,0.1); }
    .hero-gradient { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); }
  </style>
</head>
<body>
  <header class="bg-white border-b sticky top-0 z-30 shadow-sm">
    <div class="container mx-auto px-5 lg:px-8 py-4 flex items-center justify-between flex-wrap">
      <div class="flex items-center space-x-2">
        <i class="fas fa-globe-americas text-indigo-700 text-2xl"></i>
        <span class="font-bold text-2xl tracking-tight">The Global<span class="text-indigo-700">Forum</span></span>
      </div>
      <nav class="hidden md:flex space-x-6 text-gray-600 font-medium">
        <a href="/" class="hover:text-indigo-700">Home</a>
        <a href="#" class="hover:text-indigo-700">Politics</a>
        <a href="#" class="hover:text-indigo-700">Economics</a>
        <a href="#" class="hover:text-indigo-700">Geopolitics</a>
      </nav>
      <a href="/admin/" class="bg-indigo-50 text-indigo-700 px-4 py-1.5 rounded-full text-sm font-semibold hover:bg-indigo-100">Admin</a>
    </div>
  </header>

  <main class="container mx-auto px-5 lg:px-8 py-8 lg:py-12">
    {{ content | safe }}
  </main>

  <footer class="bg-white border-t mt-16 py-8 text-center text-gray-500 text-sm">
    <p>© 2025 The Global Forum. All rights reserved.</p>
  </footer>
</body>
</html>