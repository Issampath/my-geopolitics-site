---
layout: base.njk
---
<article class="max-w-3xl mx-auto bg-white rounded-2xl shadow-sm p-6 md:p-8">
  <div class="mb-4">
    <span class="bg-indigo-100 text-indigo-800 text-xs font-semibold px-3 py-1 rounded-full">{{ category or "Article" }}</span>
  </div>
  <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{{ title }}</h1>
  <div class="flex items-center text-gray-500 text-sm space-x-4 mb-6">
    <span><i class="far fa-calendar-alt mr-1"></i> {{ date | readableDate }}</span>
  </div>
  {% if image %}
  <img src="{{ image }}" alt="{{ title }}" class="w-full rounded-xl mb-6 max-h-96 object-cover">
  {% endif %}
  <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
    {{ content | safe }}
  </div>
</article>